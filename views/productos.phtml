            <input type="text" name="buscar" value="<?= htmlspecialchars($busqueda) ?>"
                   placeholder="Buscar producto..."
                   class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:border-black w-52">
            <button type="submit" class="bg-black text-white px-4 py-2 rounded-lg hover:bg-gray-800 transition-colors">Buscar</button>
        </form>
