        <p class="text-5xl mb-4">🔍</p>
        <h2 class="text-2xl font-bold text-black mb-2">No se encontraron productos</h2>
        <p class="text-gray-500 mb-6">Intenta con otra categoría o término de búsqueda</p>
        <a href="productos.php" class="inline-block bg-black text-white px-8 py-3 rounded-lg font-semibold hover:bg-gray-800 transition-colors">Ver Todos</a>
    </div>
    <?php else: ?>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        <?php foreach ($filtrados as $p):
            $imgSrc = imgUrl($p['imagen']);
        ?>
        <div class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
            <a href="<?= BASE_URL ?>/pages/producto.php?id=<?= $p['id'] ?>">
                <div class="aspect-square bg-gray-100 overflow-hidden">
                    <img src="<?= $imgSrc ?>" alt="<?= htmlspecialchars($p['nombre']) ?>" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" onerror="this.onerror=null;this.src='<?= BASE_URL ?>/assets/img/placeholder.svg'">
                </div>
                <div class="p-4">
                    <h3 class="font-semibold text-black mb-1 line-clamp-2"><?= htmlspecialchars($p['nombre']) ?></h3>
                    <p class="text-sm text-gray-500 capitalize mb-2"><?= $p['categoria'] ?></p>
                    <span class="text-xl font-bold text-black"><?= formatCOP($p['precio']) ?></span>
                    <p class="text-xs text-gray-400 mt-1">Stock: <?= $p['stock'] ?> unidades</p>
