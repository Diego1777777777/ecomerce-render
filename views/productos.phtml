<!-- Vista: Catálogo de Productos -->
<main class="py-8">
<div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-8 gap-4">
        <div>
            <h1 class="text-4xl font-bold text-black">Catálogo de Productos</h1>
            <p class="text-gray-500 mt-1"><?= count($filtrados) ?> productos encontrados</p>
        </div>
        <form method="GET" action="" class="flex gap-2">
            <?php if ($catFiltro): ?>
                <input type="hidden" name="categoria" value="<?= $catFiltro ?>">
