            <div class="px-4 pb-4">
                <button onclick="addToCart(<?= $p['id'] ?>, '<?= addslashes($p['nombre']) ?>', <?= $p['precio'] ?>, '<?= $p['imagen'] ?>', '<?= $p['categoria'] ?>', <?= $p['stock'] ?>)" class="w-full bg-black text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-gray-800 transition-colors">
