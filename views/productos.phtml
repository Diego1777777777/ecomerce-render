    <div class="flex flex-wrap gap-3 mb-10">
        <?php
        $cats = ['' => 'Todos', 'calzado' => 'Calzado', 'ropa' => 'Ropa', 'accesorios' => 'Accesorios'];
        foreach ($cats as $slug => $label):
            $active = ($catFiltro === $slug);
            $href = 'productos.php' . ($slug ? '?categoria=' . $slug : '');
            if ($busqueda) $href .= ($slug ? '&' : '?') . 'buscar=' . urlencode($busqueda);
        ?>
        <a href="<?= $href ?>" class="<?= $active ? 'bg-black text-white border-black' : 'bg-white text-black border-gray-200 hover:border-black' ?> border-2 px-6 py-2 rounded-lg font-semibold transition-all">
            <?= $label ?>
        </a>
