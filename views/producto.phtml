                    <?php foreach (explode(',', $producto['tallas']) as $talla): ?>
                    <button onclick="seleccionarTalla(this, '<?= trim($talla) ?>')" class="talla-btn px-4 py-2 border-2 border-gray-300 rounded-lg text-sm font-semibold hover:border-black transition-colors">
                        <?= trim($talla) ?>
                    </button>
