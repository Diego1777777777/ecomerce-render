<script>
let tallaSeleccionada = null;
function seleccionarTalla(btn, talla) {
    document.querySelectorAll('.talla-btn').forEach(b => {
        b.classList.remove('bg-black', 'text-white', 'border-black');
        b.classList.add('border-gray-300');
    });
    btn.classList.add('bg-black', 'text-white', 'border-black');
    btn.classList.remove('border-gray-300');
    tallaSeleccionada = talla;
    document.getElementById('talla-error')?.classList.add('hidden');
}
function agregarConTalla(id, nombre, precio, imagen, categoria, stock, tieneTallas) {
    if (tieneTallas && !tallaSeleccionada) {
        document.getElementById('talla-error')?.classList.remove('hidden');
        return;
    }
    const nombreConTalla = tieneTallas ? nombre + ' (Talla: ' + tallaSeleccionada + ')' : nombre;
    addToCart(id, nombreConTalla, precio, imagen, categoria, stock);
}
</script>
